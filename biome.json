{
	"$schema": "https://biomejs.dev/schemas/2.5.1/schema.json",
	"files": {
		"includes": ["**", "!**/vendor", "!**/data"]
	},
	"linter": {
		"rules": {
			"preset": "all",
			"correctness": { "useQwikValidLexicalScope": "off" },
			"complexity": {
				"noExcessiveCognitiveComplexity": "off",
				"noExcessiveLinesPerFunction": "off",
				"useMaxParams": "off"
			},
			"style": {
				"noTernary": "off",
				"noMagicNumbers": "off",
				"noHexColors": "off",
				"noContinue": "off",
				"useNamingConvention": "off",
				"noExcessiveLinesPerFile": "off",
				"useGlobalThis": "off"
			},
			"suspicious": {
				"noBitwiseOperators": "off",
				"noAlert": "off",
				"noUnnecessaryConditions": "off"
			}
		}
	},
	"overrides": [
		{
			"includes": ["tools/**"],
			"linter": {
				"rules": {
					"correctness": { "noNodejsModules": "off", "noProcessGlobal": "off" },
					"performance": { "noAwaitInLoops": "off" },
					"style": { "noProcessEnv": "off" },
					"suspicious": { "noConsole": "off" }
				}
			}
		}
	]
}
